# ============================================================
#  OpenClaw Docker – Umgebungsvariablen
#  Kopiere diese Datei nach .env und passe die Werte an:
#    cp .env.template .env
# ============================================================


# ------------------------------------------------------------
# Gateway – Netzwerk
# ------------------------------------------------------------

# Port, auf dem der Gateway lauscht (Standard: 18789)
OPENCLAW_GATEWAY_PORT=18789


# ------------------------------------------------------------
# Gateway – Authentifizierung
# ------------------------------------------------------------

# Auth-Token für den Gateway.
# Wird von setup.sh automatisch generiert und hier eingetragen,
# falls leer. Danach NICHT mehr ändern, solange Agents verbunden sind.
OPENCLAW_GATEWAY_TOKEN=


# ------------------------------------------------------------
# Container – Benutzer (Linux/macOS)
# ------------------------------------------------------------

# UID/GID des Host-Benutzers, damit gemountete Volumes keine
# Berechtigungsprobleme verursachen.
# Unter Windows kann dieser Block leer / auskommentiert bleiben.
HOST_UID=1000
HOST_GID=1000


# ------------------------------------------------------------
# Auto-Update beim Container-Start
# ------------------------------------------------------------

# 1 = openclaw beim Start automatisch auf die neueste Version aktualisieren (Standard)
# 0 = Update überspringen (z. B. offline / air-gapped)
OPENCLAW_AUTO_UPDATE=1


# ------------------------------------------------------------
# setup.sh – Optionen
# ------------------------------------------------------------

# Pfad zum openclaw-Konfigurations-Verzeichnis auf dem Host.
# Standard: ./agent-data/.openclaw  (relativ zum Projekt-Root)
# OPENCLAW_HOST_CONFIG_DIR=./agent-data/.openclaw

# Initialization-Befehl, der beim ersten Setup ausgeführt wird.
# Standard: "openclaw init"  – nur ändern, wenn nötig.
# OPENCLAW_INIT_CMD=openclaw init

# 1 = Initialisierung erzwingen, auch wenn bereits durchgeführt
FORCE_INIT=0

# 1 = Container nach setup.sh automatisch starten
AUTO_START=0

# 1 = Gateway-Token in der setup.sh-Ausgabe maskieren (nur Anfang/Ende sichtbar)
OPENCLAW_MASK_TOKEN_OUTPUT=0

